<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <meta name="theme-color" content="{{ settings.color_text }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    {%- liquid
      assign body_font = settings.body_font
      assign body_font_medium = body_font | font_modify: 'weight', '500'
      assign heading_font = settings.heading_font
      assign heading_font_bold = heading_font | font_modify: 'weight', 'bold'
    -%}

    <style>
      {{ body_font | font_face: font_display: 'swap' }}
      {{ body_font_medium | font_face: font_display: 'swap' }}
      {{ heading_font | font_face: font_display: 'swap' }}
      {{ heading_font_bold | font_face: font_display: 'swap' }}

      :root {
        --color-bg: {{ settings.color_bg }};
        --color-text: {{ settings.color_text }};
        --color-text-light: {{ settings.color_text | color_mix: settings.color_bg, 60 }};
        --color-accent: {{ settings.color_accent }};
        --color-accent-text: {{ settings.color_accent_text }};
        --color-border: {{ settings.color_border }};
        --color-sale: {{ settings.color_sale }};

        --body-font-family: {{ body_font.family }}, {{ body_font.fallback_families }};
        --body-font-weight: {{ body_font.weight }};
        --heading-font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        --heading-font-weight: {{ heading_font.weight }};

        --page-width: {{ settings.page_width }}px;
        --header-height: 68px;
      }
    </style>

    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}'
      };
      window.cartStrings = {
        error: {{ 'sections.cart.cart_error' | t | json }},
        quantityError: {{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' | json }}
      };
      window.moneyFormat = {{ shop.money_format | json }};
    </script>
  </head>

  <body class="template-{{ request.page_type | handle }}">
    <a class="skip-to-content" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    {% render 'cart-drawer' %}
    {% render 'quick-add' %}

    <div class="overlay" data-overlay hidden></div>

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
    </ul>
  </body>
</html>
