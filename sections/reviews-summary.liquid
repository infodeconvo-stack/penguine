<section class="section reviews">
  <div class="page-width" style="max-width: 760px;">
    {%- if section.settings.heading != blank -%}
      <h2 class="reviews__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="reviews__summary">
      <span class="reviews__stars">{% for i in (1..5) %}{% render 'icon', name: 'star' %}{% endfor %}</span>
      {%- if section.settings.review_count != blank -%}
        <span class="reviews__count">from {{ section.settings.review_count }} reviews</span>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="reviews__slider" data-reviews>
        {%- for block in section.blocks -%}
          <figure class="reviews__quote {% if forloop.first %}is-active{% endif %}" data-review {{ block.shopify_attributes }}>
            <span class="reviews__stars sm">{% for i in (1..block.settings.rating) %}{% render 'icon', name: 'star' %}{% endfor %}</span>
            <blockquote>{{ block.settings.quote }}</blockquote>
            <figcaption class="reviews__name">{{ block.settings.author }}</figcaption>
          </figure>
        {%- endfor -%}
      </div>
      {%- if section.blocks.size > 1 -%}
        <div class="reviews__nav">
          <button type="button" data-review-prev aria-label="Previous">{% render 'icon', name: 'arrow' %}</button>
          <button type="button" data-review-next aria-label="Next">{% render 'icon', name: 'arrow' %}</button>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What our Customers Say" },
    { "type": "text", "id": "review_count", "label": "Total reviews (display only)", "default": "540" },
    { "type": "paragraph", "content": "For live, verified reviews add an app like Judge.me or Loox. These are display testimonials." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "rating", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "High quality print on high quality matte poster! Cannot wait to gift it. It's perfect. Thank you!" },
        { "type": "text", "id": "author", "label": "Author", "default": "Ayesha Khan, Karachi" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review", "settings": { "quote": "Stunning colours and super fast delivery — reached me in Lahore in just 2 days. Looks incredible!", "author": "Bilal Ahmed, Lahore" } },
        { "type": "review", "settings": { "quote": "Exactly as pictured, premium feel. Already ordered two more for my cousins!", "author": "Fatima Malik, Islamabad" } }
      ]
    }
  ]
}
{% endschema %}
