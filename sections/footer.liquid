<footer class="footer">
  {%- if section.settings.newsletter_enable -%}
    <div class="footer__newsletter">
      <div class="page-width">
        <div class="footer__news-inner">
          <div class="footer__news-copy">
            {%- if section.settings.newsletter_heading != blank -%}
              <h3 class="footer__news-title">{{ section.settings.newsletter_heading }}</h3>
            {%- endif -%}
            {%- if section.settings.newsletter_text != blank -%}
              <p>{{ section.settings.newsletter_text }}</p>
            {%- endif -%}
          </div>
          <div class="footer__news-action">
            {%- form 'customer', class: 'footer__news-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <label class="visually-hidden" for="FooterEmail">{{ 'general.newsletter_form.newsletter_email' | t }}</label>
              <input id="FooterEmail" type="email" name="contact[email]" placeholder="{{ 'general.newsletter_form.email_placeholder' | t }}" required>
              <button type="submit">{{ section.settings.newsletter_button | default: 'Subscribe' }}</button>
            {%- endform -%}
            <p class="footer__news-success" data-newsletter-success hidden>{{ 'general.newsletter_form.confirmation' | t }}</p>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="page-width">
    <div class="footer__grid">

      <div class="footer__brand">
        {%- if section.settings.show_logo and settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 320 }}" alt="{{ shop.name }}" width="{{ settings.logo.width }}" height="{{ settings.logo.height }}" style="width:{{ settings.logo_width }}px;height:auto;filter:invert(1)">
        {%- else -%}
          <span class="logo-text">{{ shop.name }}</span>
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}
          <p style="margin-top:14px;max-width:34ch;opacity:.85">{{ section.settings.tagline }}</p>
        {%- endif -%}
        <div class="footer__social">
          {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}" aria-label="Instagram">{%- render 'icon', name: 'instagram' -%}</a>{%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}<a href="{{ settings.social_tiktok_link }}" aria-label="TikTok">{%- render 'icon', name: 'tiktok' -%}</a>{%- endif -%}
          {%- if settings.social_facebook_link != blank -%}<a href="{{ settings.social_facebook_link }}" aria-label="Facebook">{%- render 'icon', name: 'facebook' -%}</a>{%- endif -%}
          {%- if settings.social_whatsapp_link != blank -%}<a href="{{ settings.social_whatsapp_link }}" aria-label="WhatsApp">{%- render 'icon', name: 'whatsapp' -%}</a>{%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <div class="footer__col" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              <ul class="footer__menu">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- when 'text' -%}
            <div class="footer__col" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              <div style="font-size:.9rem;opacity:.85">{{ block.settings.text }}</div>
            </div>
        {%- endcase -%}
      {%- endfor -%}

    </div>

    <div class="footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright }}</span>
      {%- if section.settings.show_payment_icons -%}
        <span class="footer__pay">{%- for type in shop.enabled_payment_types -%}{{ type | payment_type_svg_tag: class: 'payment-icon' }}{%- endfor -%}</span>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [
    { "type": "header", "content": "Newsletter" },
    { "type": "checkbox", "id": "newsletter_enable", "label": "Show newsletter band", "default": true },
    { "type": "text", "id": "newsletter_heading", "label": "Heading", "default": "Join the list" },
    { "type": "text", "id": "newsletter_text", "label": "Text", "default": "Get 10% off your first order, plus first access to new drops." },
    { "type": "text", "id": "newsletter_button", "label": "Button", "default": "Subscribe" },
    { "type": "header", "content": "Brand" },
    { "type": "checkbox", "id": "show_logo", "label": "Show logo", "default": true },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Wearable & wall-worthy graphic art. Printed in small batches." },
    { "type": "text", "id": "copyright", "label": "Copyright note", "default": "All rights reserved." },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Help" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Email hello@yourstore.com</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Shop" } },
        { "type": "menu", "settings": { "heading": "Help" } },
        { "type": "text", "settings": { "heading": "Contact" } }
      ]
    }
  ]
}
{% endschema %}
