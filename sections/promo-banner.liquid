{%- liquid
  assign s = section.settings
  assign align = ''
  if s.align == 'left'
    assign align = 'left'
  endif
  assign tone = ''
  if s.text_color == 'dark'
    assign tone = 'text-dark'
  endif
-%}
<section class="promo" style="--veil: {{ s.overlay_opacity | divided_by: 100.0 }}; {% if s.min_height != blank %}min-height: {{ s.min_height }}px;{% endif %}">
  <div class="promo__bg">
    {%- if s.image != blank -%}
      <img src="{{ s.image | image_url: width: 2400 }}"
           srcset="{{ s.image | image_url: width: 1000 }} 1000w, {{ s.image | image_url: width: 1800 }} 1800w, {{ s.image | image_url: width: 2400 }} 2400w"
           sizes="100vw" alt="{{ s.image.alt | escape | default: s.heading }}"
           width="{{ s.image.width }}" height="{{ s.image.height }}" loading="lazy">
    {%- else -%}
      <img src="{{ 'promo-calligraphy.jpg' | asset_url }}" alt="{{ s.heading | escape }}" width="2000" height="1100" loading="lazy">
    {%- endif -%}
  </div>
  <div class="promo__overlay"></div>
  <div class="promo__content {{ align }} {{ tone }}">
    {%- if s.kicker != blank -%}<span class="promo__kicker">{{ s.kicker }}</span>{%- endif -%}
    {%- if s.heading != blank -%}<h2 class="uppercase">{{ s.heading }}</h2>{%- endif -%}
    {%- if s.text != blank -%}<p style="max-width:46ch;{% if align == 'left' %}margin-left:0{% else %}margin-left:auto;margin-right:auto{% endif %}">{{ s.text }}</p>{%- endif -%}
    {%- if s.button_label != blank -%}
      <a href="{{ s.button_link }}" class="btn mt-2" style="{% if tone == '' %}background:#fff;color:#111;border-color:#fff{% endif %}">{{ s.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Promo banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Featured collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Urdu Calligraphy" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Ink, letters, identity — calligraphy art on premium drop-shoulder tees." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore the collection" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select", "id": "align", "label": "Text position",
      "options": [{ "value": "center", "label": "Center" }, { "value": "left", "label": "Left" }],
      "default": "center"
    },
    {
      "type": "select", "id": "text_color", "label": "Text color",
      "options": [{ "value": "light", "label": "Light" }, { "value": "dark", "label": "Dark" }],
      "default": "light"
    },
    { "type": "range", "id": "overlay_opacity", "label": "Image darken", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 45 },
    { "type": "range", "id": "min_height", "label": "Height", "min": 300, "max": 800, "step": 20, "unit": "px", "default": 520 }
  ],
  "presets": [{ "name": "Promo banner" }]
}
{% endschema %}
