{%- liquid
  assign s = section.settings
  assign coll = s.collection
  assign limit = s.products_to_show
-%}
<section class="section">
  <div class="page-width">
    <div class="section-header">
      {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="uppercase">{{ s.heading }}</h2>{%- endif -%}
    </div>

    {%- if coll != blank and coll.products_count > 0 -%}
      <div class="product-grid" style="--cols: {{ s.columns }}">
        {%- for product in coll.products limit: limit -%}
          {%- render 'product-card', product: product, show_quick_add: s.show_quick_add -%}
        {%- endfor -%}
      </div>
      {%- if s.show_view_all -%}
        <div class="cta-row">
          <a href="{{ coll.url }}" class="btn btn--outline">{{ 'sections.featured_collection.view_all' | t }}</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="product-grid" style="--cols: {{ s.columns }}">
        {%- for i in (1..s.columns) -%}
          <div class="card">
            <div class="card__media">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
            <div class="card__info"><h3 class="card__title">Example product</h3><div class="price"><span class="price--regular">Rs 0</span></div></div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Fresh" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New drops" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "show_quick_add", "label": "Show quick add", "default": true },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'view all' button", "default": true }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
