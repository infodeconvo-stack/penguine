<section class="section--tight">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-header"><h2 class="uppercase">{{ section.settings.heading }}</h2></div>
    {%- endif -%}
    <div class="split">
      {%- for block in section.blocks -%}
        {%- assign coll = block.settings.collection -%}
        <a href="{{ block.settings.link | default: coll.url }}" class="split__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="900" height="1200">
          {%- elsif coll.featured_image -%}
            <img src="{{ coll.featured_image | image_url: width: 1200 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="900" height="1200">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <div class="split__overlay">
            <h3 class="uppercase">{{ block.settings.heading }}</h3>
            {%- if block.settings.subheading != blank -%}<p style="margin:0">{{ block.settings.subheading }}</p>{%- endif -%}
            <span class="link-underline mt-2">{{ block.settings.button_label | default: 'Shop now' }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dual collections",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Two ways to wear it" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Block",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "collection", "id": "collection", "label": "Collection (image fallback + link)" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Blanks" },
        { "type": "text", "id": "subheading", "label": "Subheading", "default": "Premium plain tees" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop blanks" },
        { "type": "url", "id": "link", "label": "Custom link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dual collections",
      "blocks": [
        { "type": "item", "settings": { "heading": "Blanks", "subheading": "Premium plain tees", "button_label": "Shop blanks" } },
        { "type": "item", "settings": { "heading": "Prints", "subheading": "Limited graphic drops", "button_label": "Shop prints" } }
      ]
    }
  ]
}
{% endschema %}
