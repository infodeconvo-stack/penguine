<section class="section" style="min-height:80vh;display:grid;place-items:center;text-align:center">
  <div class="page-width" style="max-width:480px">
    {%- if settings.logo != blank -%}
      <img src="{{ settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" width="{{ settings.logo.width }}" height="{{ settings.logo.height }}" style="width:{{ settings.logo_width }}px;height:auto;margin:0 auto 16px">
    {%- else -%}
      <h1 class="uppercase">{{ shop.name }}</h1>
    {%- endif -%}
    <p class="text-light">{{ section.settings.message | default: 'Opening soon. Enter the password to take a look.' }}</p>

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <p style="color:var(--color-sale)">{{ form.errors.messages.password }}</p>
      {%- endif -%}
      <div class="newsletter__form" style="max-width:360px;margin:18px auto 0">
        <input type="password" name="password" placeholder="Password" style="border-color:var(--color-border);color:var(--color-text)" required>
        <button type="submit" style="background:var(--color-accent);color:var(--color-accent-text);border-color:var(--color-accent)">Enter</button>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Password",
  "settings": [
    { "type": "text", "id": "message", "label": "Message", "default": "Opening soon. Enter the password to take a look." }
  ]
}
{% endschema %}
