<section class="section" style="text-align:center;padding:clamp(80px,12vw,160px) 0">
  <div class="page-width">
    <span class="eyebrow">404</span>
    <h1 class="uppercase">{{ 'general.404.title' | t }}</h1>
    <p class="text-light">{{ 'general.404.subtext' | t }}</p>
    <div class="cta-row">
      <a href="{{ routes.root_url }}" class="btn">{{ 'general.continue_shopping' | t }}</a>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline">Shop all</a>
    </div>
  </div>
</section>

{% schema %}
{ "name": "404", "settings": [] }
{% endschema %}
