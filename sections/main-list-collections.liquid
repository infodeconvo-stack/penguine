<section class="section">
  <div class="page-width">
    <div class="section-header">
      <h1 class="uppercase">{{ section.settings.heading | default: 'Collections' }}</h1>
    </div>
    <div class="collection-list" style="--cols: {{ section.settings.columns }}">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="collection-list__item">
          {%- if collection.featured_image -%}
            <img src="{{ collection.featured_image | image_url: width: 800 }}" alt="{{ collection.title | escape }}" loading="lazy" width="600" height="750">
          {%- else -%}
            {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
          <span class="collection-list__label">{{ collection.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "List collections",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by collection" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 3 }
  ]
}
{% endschema %}
