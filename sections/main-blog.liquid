<section class="section">
  <div class="page-width">
    <div class="section-header"><h1 class="uppercase">{{ blog.title }}</h1></div>

    {%- paginate blog.articles by 12 -%}
      <div class="product-grid" style="--cols:3">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="card">
            <div class="card__media">
              {%- if article.image -%}
                <img src="{{ article.image | image_url: width: 700 }}" alt="{{ article.title | escape }}" loading="lazy" width="600" height="800">
              {%- else -%}
                {{ 'blog-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="card__info">
              <span class="card__vendor">{{ article.published_at | date: '%b %d, %Y' }}</span>
              <h3 class="card__title">{{ article.title }}</h3>
              <p class="text-light" style="font-size:.9rem">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</p>
            </div>
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">{{ 'general.pagination.previous' | t }}</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>{%- else -%}<span class="{% if part.title == paginate.current_page %}current{% endif %}">{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">{{ 'general.pagination.next' | t }}</a>{%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
