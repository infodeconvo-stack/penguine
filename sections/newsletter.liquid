<section class="section newsletter">
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow" style="color:rgba(255,255,255,.7)">{{ section.settings.eyebrow }}</span>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="uppercase">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.text != blank -%}<p style="max-width:46ch;margin:0 auto;opacity:.85">{{ section.settings.text }}</p>{%- endif -%}

    {%- form 'customer', class: 'newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label class="visually-hidden" for="NewsletterEmail">{{ 'general.newsletter_form.newsletter_email' | t }}</label>
      <input id="NewsletterEmail" type="email" name="contact[email]" placeholder="{{ 'general.newsletter_form.email_placeholder' | t }}" required>
      <button type="submit">{{ section.settings.button_label }}</button>
    {%- endform -%}
    <p class="form-success" data-newsletter-success hidden>{{ 'general.newsletter_form.confirmation' | t }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Don't miss a drop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get early access" },
    { "type": "text", "id": "text", "label": "Text", "default": "New prints sell out fast. Join the list and get first dibs + 10% off your first order." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join the drop" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
