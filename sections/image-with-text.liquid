{%- liquid
  assign s = section.settings
  assign reverse = ''
  if s.layout == 'text_first'
    assign reverse = 'reverse'
  endif
-%}
<section class="section" {% if s.bg != blank %}style="background:{{ s.bg }}"{% endif %}>
  <div class="page-width">
    <div class="media-text {{ reverse }}">
      <div class="media-text__media">
        {%- if s.image != blank -%}
          <img src="{{ s.image | image_url: width: 1200 }}" alt="{{ s.image.alt | escape | default: s.heading }}" loading="lazy" width="800" height="1000">
        {%- else -%}
          <div class="placeholder">{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>
      <div class="media-text__content">
        {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="uppercase">{{ s.heading }}</h2>{%- endif -%}
        {%- if s.text != blank -%}<div class="text-light">{{ s.text }}</div>{%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul style="margin:18px 0;display:grid;gap:10px">
            {%- for block in section.blocks -%}
              <li {{ block.shopify_attributes }} style="display:flex;gap:10px;align-items:center">
                <span style="display:inline-flex;width:22px">{%- render 'icon', name: block.settings.icon -%}</span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if s.button_label != blank -%}
          <a href="{{ s.button_link }}" class="btn mt-2">{{ s.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "max_blocks": 4,
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select", "id": "layout", "label": "Layout",
      "options": [{ "value": "image_first", "label": "Image left" }, { "value": "text_first", "label": "Image right" }],
      "default": "image_first"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The fit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Oversized, not sloppy" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Our drop-shoulder cut sits low on the arm for that relaxed streetwear silhouette — without losing shape. Heavyweight cotton that keeps its form wash after wash.</p>" },
    { "type": "color", "id": "bg", "label": "Background (optional)" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "View size guide" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature line",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "truck", "label": "Shipping" },
            { "value": "return", "label": "Returns" },
            { "value": "ruler", "label": "Fit / size" },
            { "value": "star", "label": "Quality" }
          ],
          "default": "ruler"
        },
        { "type": "text", "id": "text", "label": "Text", "default": "230 GSM heavyweight cotton" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with text",
      "blocks": [
        { "type": "feature", "settings": { "icon": "ruler", "text": "230 GSM heavyweight cotton" } },
        { "type": "feature", "settings": { "icon": "truck", "text": "Free shipping over Rs 5,000" } },
        { "type": "feature", "settings": { "icon": "return", "text": "7-day easy exchange" } }
      ]
    }
  ]
}
{% endschema %}
