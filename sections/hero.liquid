{%- liquid
  assign s = section.settings
  assign align = ''
  if s.align == 'center'
    assign align = 'align-center'
  endif
  assign tone = ''
  if s.text_color == 'dark'
    assign tone = 'text-dark'
  endif
-%}
<section class="hero hero--{{ s.height }}">
  <div class="hero__media">
    {%- if s.image != blank -%}
      <img src="{{ s.image | image_url: width: 2400 }}"
           srcset="{{ s.image | image_url: width: 800 }} 800w, {{ s.image | image_url: width: 1400 }} 1400w, {{ s.image | image_url: width: 2400 }} 2400w"
           sizes="100vw" alt="{{ s.image.alt | escape | default: s.heading }}"
           width="{{ s.image.width }}" height="{{ s.image.height }}" fetchpriority="high">
    {%- else -%}
      <img src="{{ 'hero-custom.jpg' | asset_url }}" alt="{{ s.heading | escape | default: shop.name }}" width="2400" height="900" fetchpriority="high">
    {%- endif -%}

    {%- if s.overlay_opacity > 0 -%}
      <div class="hero__veil" style="background: rgba(0,0,0,{{ s.overlay_opacity | divided_by: 100.0 }});"></div>
    {%- endif -%}

    <div class="hero__content {{ align }} {{ tone }}">
      {%- if s.eyebrow != blank -%}<span class="eyebrow">{{ s.eyebrow }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<h1 class="uppercase">{{ s.heading }}</h1>{%- endif -%}
      {%- if s.subheading != blank -%}<p style="max-width:46ch">{{ s.subheading }}</p>{%- endif -%}
      <div class="hero__cta">
        {%- if s.button_label != blank -%}
          <a href="{{ s.button_link }}" class="btn">{{ s.button_label }}</a>
        {%- endif -%}
        {%- if s.button_label_2 != blank -%}
          <a href="{{ s.button_link_2 }}" class="btn btn--outline" style="{% if tone == '' %}color:#fff;border-color:#fff{% endif %}">{{ s.button_label_2 }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    {
      "type": "select", "id": "height", "label": "Height",
      "options": [{ "value": "medium", "label": "Medium" }, { "value": "full", "label": "Full screen" }],
      "default": "full"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New season" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Drop-shoulder, done right" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium oversized tees — blanks and limited prints. Built for the fit." },
    { "type": "text", "id": "button_label", "label": "Button 1 label", "default": "Shop prints" },
    { "type": "url", "id": "button_link", "label": "Button 1 link" },
    { "type": "text", "id": "button_label_2", "label": "Button 2 label", "default": "Shop blanks" },
    { "type": "url", "id": "button_link_2", "label": "Button 2 link" },
    {
      "type": "select", "id": "align", "label": "Text position",
      "options": [{ "value": "left", "label": "Bottom left" }, { "value": "center", "label": "Center" }],
      "default": "left"
    },
    {
      "type": "select", "id": "text_color", "label": "Text color",
      "options": [{ "value": "light", "label": "Light" }, { "value": "dark", "label": "Dark" }],
      "default": "light"
    },
    { "type": "range", "id": "overlay_opacity", "label": "Image darken", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 50 }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
